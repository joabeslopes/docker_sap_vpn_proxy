# VPN OpenVPN
VPN_USER=user
VPN_PASSWORD=password
VPN_CONFIG=CONF.ovpn

# Sufixo das portas do host
HOST_PORT_SUFIX_DEV=01
HOST_PORT_SUFIX_QAS=02
HOST_PORT_SUFIX_PRD=03

# IP dos ambientes SAP
SAP_IP_DEV=1.1.1.1
SAP_IP_QAS=1.1.1.2
SAP_IP_PRD=1.1.1.3

# Numero da instancia dos ambientes SAP
SAP_NI_DEV=00
SAP_NI_QAS=00
SAP_NI_PRD=00
